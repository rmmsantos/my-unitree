# Copy this file to .env and replace the placeholder below.
OPENAI_API_KEY=replace_with_your_api_key

OPENAI_REALTIME_MODEL=gpt-realtime-2.1
OPENAI_REALTIME_VOICE=marin

# Use "local" on a workstation or "unitree" on the G1 PC2.
AUDIO_BACKEND=local
AUDIO_DEBUG=false
ROBOT_BEHAVIOR_TOOLS_ENABLED=true
COMPANY_KNOWLEDGE_TOOLS_ENABLED=true
# COMPANY_KNOWLEDGE_PATH=/home/rmartins/work/my-unitree/conversation/knowledge/digitalsign.json

# Required only when AUDIO_BACKEND=unitree.
# Optional when commands are run outside the repository:
# UNITREE_PROJECT_ROOT=/home/rmartins/work/my-unitree
UNITREE_INTERFACE_IP=192.168.123.164
UNITREE_NETWORK_INTERFACE=eth0
UNITREE_MIC_MULTICAST_GROUP=239.168.123.161
UNITREE_MIC_PORT=5555

# Local RealSense streams reported by v4l2-ctl --list-formats-ext.
# The colour stream is obtained through the official Unitree VideoClient.
UNITREE_DEPTH_CAMERA_DEVICE=/dev/video0
UNITREE_INFRARED_CAMERA_DEVICE=/dev/video2
