# Copia este ficheiro para .env e substitui o valor abaixo.
OPENAI_API_KEY=coloca_a_tua_api_key_aqui

# Podes trocar o modelo sem alterar o código.
OPENAI_MODEL=gpt-5.6-terra

# Configuração da entrada e saída de voz.
OPENAI_TRANSCRIPTION_MODEL=gpt-4o-mini-transcribe
OPENAI_TTS_MODEL=gpt-4o-mini-tts
OPENAI_TTS_VOICE=marin

# Conversa speech-to-speech com baixa latência.
OPENAI_REALTIME_MODEL=gpt-realtime-2.1
OPENAI_REALTIME_VOICE=marin
AUDIO_DEBUG=false

# Usa "local" no computador ou "unitree" no PC2 do G1.
AUDIO_BACKEND=local

# Necessário apenas com AUDIO_BACKEND=unitree.
UNITREE_INTERFACE_IP=192.168.123.164
UNITREE_NETWORK_INTERFACE=eth0
UNITREE_SDK_PATH=/home/rmartins/work/unitree_sdk2_python
UNITREE_MIC_MULTICAST_GROUP=239.168.123.161
UNITREE_MIC_PORT=5555
